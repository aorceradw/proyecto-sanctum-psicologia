# Sanctum Environment Variables
# Copy this file to .env and fill in the actual values

# Server Configuration
PORT=3001
NODE_ENV=production

# Client Configuration (for CORS)
CLIENT_ORIGIN=https://yourdomain.com

# Render.com specific (if deploying there)
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Google Gemini API (for AI assistant)
# Get your API key from: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key-here

# Database (SQLite runs locally, no config needed)
# DATABASE_PATH=./db/sanctum.db (uses default)
